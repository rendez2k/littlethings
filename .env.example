# Copy to .env.local and fill in to enable optional accounts.
# Accounts are optional — the app works fully without these.
#
# Use only the PUBLISHABLE / ANON key here. It is designed to be exposed in the
# browser. NEVER put a service-role key in a NEXT_PUBLIC_* variable.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Optional: Web Push reminders (see docs/PUSH.md).
# The PUBLIC VAPID key only — the private key is a Supabase function secret.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
